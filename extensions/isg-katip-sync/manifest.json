{
  "manifest_version": 3,
  "name": "İSG Panel İSG-KATİP Senkronizasyonu",
  "version": "0.5.10",
  "description": "Açık İSG-KATİP sayfasındaki firma ve atama bilgilerini İSG Panel'e güvenli şekilde aktarır.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": [
    "https://*.isgkatip.csgb.gov.tr/*",
    "https://isgkatip.csgb.gov.tr/*",
    "https://api.isgpanel.tr/*",
    "https://app.isgpanel.tr/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup.html",
    "default_title": "İSG-KATİP Senkronize Et"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://app.isgpanel.tr/*"],
      "js": ["panel-bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.isgkatip.csgb.gov.tr/*",
        "https://isgkatip.csgb.gov.tr/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
